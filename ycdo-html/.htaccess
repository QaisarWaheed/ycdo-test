RewriteEngine On

# HTTPS redirect: skip when TLS is already terminated upstream (CapRover / nginx / Cloudflare)
RewriteCond %{HTTP:X-Forwarded-Proto} !^https$ [NC]
RewriteCond %{HTTPS} off
# 307 (not 301) so POST body is preserved when upgrading HTTP to HTTPS
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=307]
