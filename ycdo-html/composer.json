{
    "name": "ycdo/hospital-management-system",
    "description": "YCDO Hospital Management System",
    "type": "project",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "files": [
            "includes/report_helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ycdo\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:quality": "phpunit --testsuite quality",
        "test:unit": "phpunit --testsuite unit",
        "build": [
            "@test",
            "@php tests/run_all.php"
        ]
    }
}
